# Database (SQLite local; use postgres URL in production)
DATABASE_URL="file:./dev.db"

# Privy — https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Mainnet USDC mint
NEXT_PUBLIC_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Polymarket (Gamma + CLOB). Leave empty to use fixture/paper mode.
POLYMARKET_API_BASE=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE=https://clob.polymarket.com
POLYMARKET_API_KEY=
POLYMARKET_API_KEY_SECONDARY=
POLYMARKET_ACTIVE_KEY=primary

# Kalshi — live when keys present; otherwise stub adapter
KALSHI_API_BASE=https://trading-api.kalshi.com/trade-api/v2
KALSHI_API_KEY=
KALSHI_API_KEY_SECONDARY=
KALSHI_ACTIVE_KEY=primary

# Prompt pipeline (optional — heuristic fallback if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEMO_MODE=true
